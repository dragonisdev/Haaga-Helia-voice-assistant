# ============================================================================
# LIVEKIT VOICE AI AGENT - ENVIRONMENT CONFIGURATION
# ============================================================================
# This agent connects to LiveKit as a worker and handles voice calls
# for multi-tenant SaaS applications.

# ============================================================================
# LIVEKIT CONNECTION (REQUIRED)
# ============================================================================
# Your LiveKit server URL
LIVEKIT_URL=wss://<your-project>.livekit.cloud

# LiveKit API credentials (from LiveKit Cloud dashboard)
LIVEKIT_API_KEY=<your-api-key>
LIVEKIT_API_SECRET=<your-api-secret>

# ============================================================================
# Your backend API URL (where the agent will send transcripts)
API_BASE_URL=https://voice-agent-saas-production.up.railway.app

# Service token for agent → backend authentication
SERVICE_TOKEN=xqUnTHwkN0erKHde9LS53ctdnja2qFrOY7Uf0zNVBkE

# OpenAI API key for LLM and TTS
OPENAI_API_KEY=<your-openai-api-key>

# LLM model choice
LLM_CHOICE=gpt-4o-mini

# Deepgram API key for real-time transcription
DEEPGRAM_API_KEY=<your-deepgram-api-key>

# ============================================================================
# OPTIONAL: Custom Configuration
# ============================================================================
# Default language for STT (can be overridden per-user)
DEFAULT_LANGUAGE=en

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
